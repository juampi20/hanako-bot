# ──────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT
# Copiá este archivo a .env.production y completá los valores.
# NUNCA commitees .env.production — está en .gitignore.
# ──────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────
DEBUG=false

# ── Database (PostgreSQL) ─────────────────────────────────
# Obtené esta URL de tu proveedor cloud:
#   Fly.io:   flyctl postgres attach
#   Railway:  provista automáticamente en RAILWAY_DATABASE_URL
#   Neon:     del dashboard de Neon
#   Supabase: del panel de project settings > connection string
DATABASE_URL=postgres://user:password@host:5432/hanako?sslmode=require

# ── Discord ────────────────────────────────────────────────
CLIENT_TOKEN=
OWNER_ID=
GUILD_ID=
MODERATOR_ROLE_ID=
PREFIX=!

# ── Leveling ──────────────────────────────────────────────
CHAT_XP_MIN=15
CHAT_XP_MAX=25
VOICE_XP_MIN=3
VOICE_XP_MAX=5
LEVEL_UP_NOTIFY=false
LEVEL_UP_NOTIFY_INTERVAL=5
LEVEL_UP_CHANNEL_ID=

# ── AFK ────────────────────────────────────────────────────
AFK_NOTIFY=false
AFK_AUTOREPLY=true
AFK_CHANNEL_ID=

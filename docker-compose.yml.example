# ──────────────────────────────────────────────────────────
# Ejemplo autocontenido para desarrollo local.
# Incluye PostgreSQL, no necesita infraestructura externa.
#
# Uso:
#   cp docker-compose.yml.example docker-compose.yml
#   # editá .env con CLIENT_TOKEN, GUILD_ID, etc.
#   docker compose up -d
# ──────────────────────────────────────────────────────────

services:
  bot:
    build: .
    container_name: hanako-bot
    restart: unless-stopped
    env_file:
      - .env
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - hanako-net

  postgres:
    image: postgres:17-alpine
    container_name: hanako-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: hanako
      POSTGRES_USER: hanako
      POSTGRES_PASSWORD: hanako
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hanako"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - hanako-net

volumes:
  pgdata:

networks:
  hanako-net:

# Discord bot token (from https://discord.com/developers/applications)
CLIENT_TOKEN=
# Bot command prefix
PREFIX=!
# Discord user ID of the bot owner
OWNER_ID=
# XP range per message (random between xpMin and xpMax)
XP_MIN=15
XP_MAX=25
# Channel ID for level-up notifications (optional, defaults to message channel)
LEVEL_UP_CHANNEL_ID=
# Guild ID for development slash command registration (global registration will be added later)
DEV_GUILD_ID=
# Comma-separated list of moderator user IDs (for moderatorOnly commands)
MODERATOR_IDS=
# Voice XP: XP per interval (default 4) and interval in seconds (default 60)
VOICE_XP_AMOUNT=4
VOICE_XP_INTERVAL=60
# Set to "true" to enable debug logging
DEBUG=true
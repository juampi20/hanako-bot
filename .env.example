# ──────────────────────────────────────────────────────────
# DEV ENVIRONMENT
# Copiá este archivo a .env y completá los valores.
# NUNCA commitees .env — está en .gitignore.
# ──────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────
DEBUG=true

# ── Database (PostgreSQL) ─────────────────────────────────
# Si usás docker-compose.yml.example, este DATABASE_URL funciona
# tal cual (user=hanako, password=hanako, host=postgres).
# Si tenés tu propia instancia, ajustá user:password:host.
# Usá DATABASE_URL (más simple) o las vars individuales, no ambas.
DATABASE_URL=postgres://hanako:hanako@postgres:5432/hanako
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=hanako

# ── Discord ────────────────────────────────────────────────
CLIENT_TOKEN=                                                                           # Discord bot token
OWNER_ID=                                                                               # Discord user ID of the bot owner
GUILD_ID=                                                                               # Discord server ID
MODERATOR_ROLE_ID=                                                                      # Discord role ID for moderators
PREFIX=!

# ── Leveling ──────────────────────────────────────────────
CHAT_XP_MIN=15                                                                          # Min XP per chat message
CHAT_XP_MAX=25                                                                          # Max XP per chat message
VOICE_XP_MIN=3                                                                          # Min XP per minute in voice
VOICE_XP_MAX=5                                                                          # Max XP per minute in voice
LEVEL_UP_NOTIFY=false                                                                   # Enable level-up notifications
LEVEL_UP_NOTIFY_INTERVAL=5                                                              # Interval in levels
LEVEL_UP_CHANNEL_ID=                                                                    # Channel for level-up notifications

# ── AFK ────────────────────────────────────────────────────
AFK_NOTIFY=false                                                                        # Send AFK notifications
AFK_AUTOREPLY=true                                                                      # Auto-reply when mentioned AFK
AFK_CHANNEL_ID=                                                                         # Channel for AFK notifications

# --- Discord configs ---
CLIENT_TOKEN=                                                                           # Discord bot token (from https://discord.com/developers/applications)
OWNER_ID=                                                                               # Discord user ID of the bot owner (for ownerOnly commands)
GUILD_ID=                                                                               # Discord server ID (for guildOnly commands)
MODERATOR_ROLE_ID=                                                                      # Discord role ID for moderators (for modOnly commands)
PREFIX=!
# --- Sistema de niveles ---
CHAT_XP_MIN=15                                                                          # Minimum XP gained per chat message (default: 15)
CHAT_XP_MAX=25                                                                          # Maximum XP gained per chat message (default: 25)
VOICE_XP_MIN=3                                                                          # Minimum XP gained per minute in voice chat (default: 3)
VOICE_XP_MAX=5                                                                          # Maximum XP gained per minute in voice chat (default: 5)
LEVEL_UP_NOTIFY=false                                                                   # Activate level-up notifications (default: false)
LEVEL_UP_NOTIFY_INTERVAL=5                                                              # Interval level-up notifications (default: 5, in levels)
LEVEL_UP_CHANNEL_ID=                                                                    # Channel ID for level-up notifications (optional, defaults to message channel)